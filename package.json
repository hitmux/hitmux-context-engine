{
    "name": "hitmux-context-engine",
    "version": "0.1.22",
    "description": "A powerful code indexing tool with multi-platform support",
    "private": true,
    "scripts": {
        "build": "pnpm clean:build && tsc --build --force packages/core packages/mcp && pnpm build:aliases",
        "build:core": "pnpm --filter @hitmux/hitmux-context-engine-core build",
        "build:mcp": "pnpm clean:build && tsc --build --force packages/core packages/mcp",
        "build:aliases": "pnpm -r --parallel --filter @hitmux/hce --filter hce-mcp --filter @hitmux/hitmux-context-engine build",
        "build:examples": "pnpm build:core && pnpm -r --parallel --filter='./examples/*' build",
        "dev": "pnpm -r --filter='./packages/*' dev",
        "dev:core": "pnpm --filter @hitmux/hitmux-context-engine-core dev",
        "dev:mcp": "pnpm --filter @hitmux/hitmux-context-engine-mcp dev",
        "clean": "pnpm -r --parallel --filter='./packages/*' clean",
        "clean:build": "pnpm -r --parallel --filter @hitmux/hitmux-context-engine-core --filter @hitmux/hitmux-context-engine-mcp clean",
        "lint": "pnpm -r --parallel --filter='./packages/*' lint",
        "lint:fix": "pnpm -r --parallel --filter='./packages/*' run lint:fix",
        "typecheck": "pnpm build:core && pnpm typecheck:packages",
        "typecheck:packages": "pnpm -r --parallel --filter @hitmux/hitmux-context-engine-core --filter @hitmux/hitmux-context-engine-mcp run typecheck",
        "test": "pnpm build:core && pnpm test:packages",
        "test:packages": "pnpm -r --parallel --filter @hitmux/hitmux-context-engine-core --filter @hitmux/hitmux-context-engine-mcp test",
        "release:core": "pnpm build:core && pnpm --filter @hitmux/hitmux-context-engine-core publish --access public --no-git-checks",
        "release:mcp": "pnpm --filter @hitmux/hitmux-context-engine-mcp publish --access public --no-git-checks",
        "release:hce": "pnpm --filter @hitmux/hce publish --access public --no-git-checks",
        "release:hce-mcp": "pnpm --filter hce-mcp publish --access public --no-git-checks",
        "release:hitmux-context-engine": "pnpm --filter @hitmux/hitmux-context-engine publish --access public --no-git-checks",
        "release:aliases": "pnpm release:hce && pnpm release:hce-mcp && pnpm release:hitmux-context-engine",
        "example:basic": "pnpm --filter hitmux-context-engine-basic-example start",
        "benchmark": "node scripts/build-benchmark.js",
        "benchmark:search:cannonwar": "pnpm build:core && pnpm --dir packages/mcp exec tsx ../../evaluation/search-quality/run-cannonwar-search-quality.ts"
    },
    "devDependencies": {
        "@eslint/js": "^9.28.0",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^8.31.1",
        "@typescript-eslint/parser": "^8.31.1",
        "eslint": "^9.25.1",
        "rimraf": "^6.0.1",
        "typescript": "^5.8.3"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/hitmux/hitmux-context-engine.git"
    },
    "license": "MIT",
    "author": "Cheney Zhang <277584121@qq.com>"
}
