{
    "name": "@hitmux/hitmux-context-engine-mcp",
    "version": "0.1.15",
    "description": "Model Context Protocol integration for Hitmux Context Engine",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": "dist/index.js",
    "scripts": {
        "build": "pnpm clean && tsc --build --force",
        "dev": "tsx --watch src/index.ts",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "typecheck": "tsc --noEmit",
        "test": "node --import tsx --test \"src/**/*.test.ts\"",
        "start": "tsx src/index.ts",
        "start:with-config": "tsx src/index.ts",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "@hitmux/hitmux-context-engine-core": "workspace:*",
        "@modelcontextprotocol/sdk": "^1.12.1",
        "zod": "^3.25.55"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "tsx": "^4.19.4",
        "typescript": "^5.0.0"
    },
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/hitmux/hitmux-context-engine.git",
        "directory": "packages/mcp"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
