{
    "name": "@hitmux/hitmux-context-engine-core",
    "version": "0.1.22",
    "description": "Core indexing engine for Hitmux Context Engine",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "pnpm clean && tsc --build --force",
        "dev": "tsc --watch",
        "clean": "rimraf dist tsconfig.tsbuildinfo",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "typecheck": "tsc --noEmit",
        "test": "node --no-deprecation ./node_modules/jest/bin/jest.js --runInBand"
    },
    "dependencies": {
        "@google/genai": "^1.9.0",
        "@langchain/textsplitters": "^0.1.0",
        "@zilliz/milvus2-sdk-node": "^2.5.10",
        "ignore": "^7.0.5",
        "ollama": "^0.5.16",
        "openai": "^5.1.1",
        "tree-sitter": "^0.21.1",
        "tree-sitter-c-sharp": "^0.21.0",
        "tree-sitter-cpp": "^0.22.0",
        "tree-sitter-go": "^0.21.0",
        "tree-sitter-java": "^0.21.0",
        "tree-sitter-javascript": "^0.21.0",
        "tree-sitter-python": "^0.21.0",
        "tree-sitter-rust": "^0.21.0",
        "tree-sitter-scala": "^0.24.0",
        "tree-sitter-typescript": "^0.21.0",
        "voyageai": "^0.0.4"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/mock-fs": "^4.13.4",
        "jest": "^30.0.0",
        "mock-fs": "^5.5.0",
        "ts-jest": "^29.4.0"
    },
    "files": [
        "dist",
        "src",
        "!src/**/*.test.ts"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/hitmux/hitmux-context-engine.git",
        "directory": "packages/core"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
